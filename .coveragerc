[run]
branch = True
relative_files = True
source =
    funding_bot
    web
    cache_manager
omit =
    tests/*

[report]
precision = 1
show_missing = True
skip_empty = True
exclude_also =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:

[html]
directory = htmlcov
title = Funding Bot coverage

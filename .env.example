# funding-bot local/development example environment
# Copy this file to .env and adjust values for your setup.

# Core application
# Local Python run: funding_bot.db
# Docker/Kubernetes: /app/data/funding_bot.db
BOT_DB_PATH=/app/data/funding_bot.db
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Dashboard authentication and sessions
ADMIN_PASSWORD=changeme-admin
STAFF_PASSWORD=changeme-staff
AUDITOR_PASSWORD=changeme-auditor
FLASK_SECRET_KEY=dev-only-change-me
# Legacy fallback if FLASK_SECRET_KEY is unset
SECRET_KEY=development-only-change-me
DASHBOARD_SESSION_TIMEOUT_MINUTES=30
# Set to 0 for local HTTP development; use 1 behind HTTPS
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax

# SMTP / email delivery
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
SMTP_FROM=

# Data residency, privacy, and encryption
DATA_RESIDENCY=US
DATA_STORAGE_REGION=US
PRIVACY_POLICY_OUTPUT_DIR=/app/data/privacy_policies
FUNDING_BOT_ENCRYPTION_KEY=replace-me-with-a-random-secret

# Task queue and scheduling
ENABLE_TASK_QUEUE=1
ENABLE_LEGACY_CRON=1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_QUEUE_NAME=funding-bot
CELERY_TASK_ALWAYS_EAGER=0
CELERY_HEALTH_TIMEOUT_SECONDS=2.0
CELERY_INSPECT_TIMEOUT_SECONDS=2.0
CELERY_FILESYSTEM_BROKER_DIR=.celery-broker
FUNDING_BOT_TASK_RETRY_LIMIT=3
FUNDING_BOT_TASK_RETRY_BACKOFF_SECONDS=5
FUNDING_BOT_TASK_RETRY_BACKOFF_MAX_SECONDS=300
DAILY_SUMMARY_RECIPIENT=team@example.org
DAILY_SUMMARY_DRY_RUN=0
DAILY_SUMMARY_SCHEDULE_HOUR=9
DAILY_SUMMARY_SCHEDULE_MINUTE=0
FLOWER_BASIC_AUTH=

# Connector and discovery settings
FUNDING_BOT_CONNECTORS=
FUNDING_BOT_ALLOW_INSECURE_CONNECTOR_URLS=0
PORTAL_PAGE_SIZE=100
PORTAL_CACHE_TTL=300
PORTAL_FALLBACK_MODE=cache-first
PORTAL_RATE_LIMIT_DEFAULT_CAPACITY=5
PORTAL_RATE_LIMIT_DEFAULT_REFILL_RATE=1
OAUTH2_REFRESH_SKEW_SECONDS=60
GRANTS_GOV_API_BASE_URL=https://api.grants.gov/v1/api/search2
CSR_NETWORK_API_BASE_URL=https://api.candid.org/rfp/v1/opportunity
NGO_DIRECTORY_API_BASE_URL=https://projects.propublica.org/nonprofits/api/v2/search.json
FOUNDATION_DIRECTORY_API_BASE_URL=https://api.candid.org/grants/v1/transactions
GRANTS_GOV_API_CREDENTIALS=
CSR_NETWORK_API_CREDENTIALS=
FOUNDATION_DIRECTORY_API_CREDENTIALS=

# Per-connector overrides (optional)
GRANTS_PORTAL_PAGE_SIZE=100
GRANTS_PORTAL_CACHE_TTL=300
GRANTS_PORTAL_RATE_LIMIT_CAPACITY=5
GRANTS_PORTAL_RATE_LIMIT_REFILL_RATE=1
CSR_NETWORK_PAGE_SIZE=100
CSR_NETWORK_CACHE_TTL=300
CSR_NETWORK_RATE_LIMIT_CAPACITY=5
CSR_NETWORK_RATE_LIMIT_REFILL_RATE=1
NGO_DIRECTORY_PAGE_SIZE=100
NGO_DIRECTORY_CACHE_TTL=300
NGO_DIRECTORY_RATE_LIMIT_CAPACITY=5
NGO_DIRECTORY_RATE_LIMIT_REFILL_RATE=1
FOUNDATION_DIRECTORY_PAGE_SIZE=100
FOUNDATION_DIRECTORY_CACHE_TTL=300
FOUNDATION_DIRECTORY_RATE_LIMIT_CAPACITY=5
FOUNDATION_DIRECTORY_RATE_LIMIT_REFILL_RATE=1
GLOBALGIVING_PAGE_SIZE=100
GLOBALGIVING_CACHE_TTL=300
GLOBALGIVING_RATE_LIMIT_CAPACITY=5
GLOBALGIVING_RATE_LIMIT_REFILL_RATE=1
KICKSTARTER_FOR_GOOD_PAGE_SIZE=100
KICKSTARTER_FOR_GOOD_CACHE_TTL=300
KICKSTARTER_FOR_GOOD_RATE_LIMIT_CAPACITY=5
KICKSTARTER_FOR_GOOD_RATE_LIMIT_REFILL_RATE=1

# Collaboration notifications
TASK_ASSIGNMENT_NOTIFICATION_RATE_LIMIT_SECONDS=3600

# Data retention defaults
RETENTION_AUDIT_LOG_DAYS=365
RETENTION_COMMUNICATION_DAYS=365
RETENTION_DOCUMENT_DAYS=180
RETENTION_SUBMISSION_ATTEMPT_DAYS=90
RETENTION_COMPLETED_TASK_DAYS=180

# GDPR report retention windows
GDPR_DONOR_RETENTION_DAYS=365
GDPR_COMMUNICATION_RETENTION_DAYS=730
GDPR_APPLICATION_RETENTION_DAYS=1095

# Accessibility test runner (optional)
ACCESSIBILITY_BASE_URL=http://127.0.0.1:5001
ACCESSIBILITY_USERNAME=
ACCESSIBILITY_PASSWORD=

# Example JSON values:
# FUNDING_BOT_CONNECTORS={"connectors":[{"type":"globalgiving","transport":"http"}]}
# FUNDING_BOT_ALLOW_INSECURE_CONNECTOR_URLS=1
# GRANTS_GOV_API_CREDENTIALS={"api_key":"replace-me"}
# CSR_NETWORK_API_CREDENTIALS={"subscription_key":"replace-me"}
# FOUNDATION_DIRECTORY_API_CREDENTIALS={"api_key":"replace-me"}

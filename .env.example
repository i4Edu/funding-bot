SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
SMTP_FROM=
BOT_DB_PATH=/app/data/funding_bot.db
DATA_RESIDENCY=US
DATA_STORAGE_REGION=US
PRIVACY_POLICY_OUTPUT_DIR=/app/data/privacy_policies
ENABLE_TASK_QUEUE=1
ENABLE_LEGACY_CRON=1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_QUEUE_NAME=funding-bot
CELERY_HEALTH_TIMEOUT_SECONDS=2.0
CELERY_TASK_ALWAYS_EAGER=0
ADMIN_PASSWORD=changeme
STAFF_PASSWORD=changeme
AUDITOR_PASSWORD=changeme
FUNDING_BOT_ENCRYPTION_KEY=replace-with-a-unique-key

# Optional: Flask host/port overrides (defaults: 127.0.0.1 / 5000)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Optional: portal connector query cache TTL in seconds (default: 300)
# PORTAL_CACHE_TTL=300

# Optional: live connector credentials as JSON blobs
# GRANTS_GOV_API_CREDENTIALS={"token_url":"https://auth.example.org/oauth/token","client_id":"...","client_secret":"...","credentials":{"api_key":"..."}}
# CSR_NETWORK_API_CREDENTIALS={"subscription_key":"..."}
# GRANTS_GOV_API_BASE_URL=https://api.grants.gov/v1/api/search2
# CSR_NETWORK_API_BASE_URL=https://api.candid.org/rfp/v1/opportunity

# RabbitMQ broker example:
# CELERY_BROKER_URL=amqp://<user>:<password>@rabbitmq:5672//

# Optional: retention policy defaults for automated cleanup
RETENTION_AUDIT_LOG_DAYS=365
RETENTION_COMMUNICATION_DAYS=365
RETENTION_DOCUMENT_DAYS=180
RETENTION_SUBMISSION_ATTEMPT_DAYS=90
RETENTION_COMPLETED_TASK_DAYS=180
